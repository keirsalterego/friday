{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Friday",
  "version": "0.1.0",
  "identifier": "dev.friday.desktop",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "bun run --cwd frontend dev",
    "beforeBuildCommand": "bun run --cwd frontend build"
  },
  "app": {
    "windows": [
      {
        "title": "Friday",
        "width": 1280,
        "height": 820,
        "minWidth": 800,
        "minHeight": 560,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
